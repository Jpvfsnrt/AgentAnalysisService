{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AnalysisService": {
    "MaxFileSizeMB": 200,
    "MaxConcurrentAnalyses": 4,
    "CacheExpirationMinutes": 30,
    "AllowedExtensions": [".dll", ".exe", ".netmodule", ".winmd"]
  }
}
